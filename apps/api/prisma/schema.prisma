generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum JobStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

model IngestionJob {
  id              String         @id @default(cuid())
  status          JobStatus      @default(PENDING)
  sourceType      String         @default("api")
  errorMessage    String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  rawPayload      RawPayload?
  fuelReport      FuelReport?
  voyageTelemetry VoyageTelemetry[]

  @@map("ingestion_jobs")
}

model RawPayload {
  id              String         @id @default(cuid())
  payload         Json
  ingestionJobId  String         @unique
  createdAt       DateTime       @default(now())
  ingestionJob    IngestionJob   @relation(fields: [ingestionJobId], references: [id], onDelete: Cascade)

  @@map("raw_payloads")
}

model FuelReport {
  id               String         @id @default(cuid())
  vesselCode       String
  reportMonth      String
  routeId          String
  distanceNm       Float
  fuelConsumedTons Float
  fuelType         String
  weather          String?
  engineEfficiency Float?
  ingestionJobId   String         @unique
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  ingestionJob     IngestionJob   @relation(fields: [ingestionJobId], references: [id], onDelete: Cascade)
  vessel           Vessel         @relation(fields: [vesselCode], references: [code])
  anomalies        Anomaly[]

  @@unique([vesselCode, reportMonth, routeId])
  @@map("fuel_reports")
}

model Vessel {
  code                    String         @id
  name                    String
  fuelEfficiencyBenchmark Float
  createdAt               DateTime       @default(now())
  updatedAt               DateTime       @updatedAt
  fuelReports             FuelReport[]
  anomalies               Anomaly[]

  @@map("vessels")
}

enum AnomalyType {
  FUEL_VARIANCE
}

enum AnomalySeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum AnomalyStatus {
  OPEN
  INVESTIGATING
  RESOLVED
  FALSE_POSITIVE
}

model Anomaly {
  id              String          @id @default(cuid())
  type            AnomalyType
  severity        AnomalySeverity
  vesselCode      String
  fuelReportId    String
  expectedValue   Float
  actualValue     Float
  variancePercent Float
  description     String
  status          AnomalyStatus   @default(OPEN)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  vessel          Vessel          @relation(fields: [vesselCode], references: [code])
  fuelReport      FuelReport      @relation(fields: [fuelReportId], references: [id])

  @@index([vesselCode, status])
  @@map("anomalies")
}

model VoyageTelemetry {
  id                String   @id @default(cuid())
  vesselTrackingId  String
  timestamp         DateTime
  latitude          Float
  longitude         Float
  speedOverGround   Float
  courseOverGround  Float?
  heading           Float?
  vesselName        String?
  imoNumber         String?
  navigationStatus  String
  ingestionJobId    String   @unique
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  ingestionJob      IngestionJob @relation(fields: [ingestionJobId], references: [id], onDelete: Cascade)

  @@unique([vesselTrackingId, timestamp])
  @@map("voyage_telemetry")
}

model PortBenchmark {
  id                    String  @id @default(cuid())
  economyLabel          String
  marketType            String
  medianPortStayDays    Float
  avgVesselAgeYears     Float
  avgVesselSizeGt       Float
  period                String
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@map("port_benchmarks")
}
